# Embryo Agent 环境变量配置
# 复制为 .env 并填入真实值

# 必须: LLM API Key
OPENAI_API_KEY=sk-your-key-here

# 可选: 自定义 API 端点（兼容 OpenAI 接口的服务）
# OPENAI_BASE_URL=https://your-api-endpoint/v1

# 可选: 模型名称
EMBRYO_MODEL=gpt-4o

# 可选: Telegram Bot Token（启用 --telegram 时需要）
# TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token

# 日志级别
EMBRYO_LOG_LEVEL=INFO
